<footer id="footer">
  <div class="outer">
    <% if (theme.menu && Object.keys(theme.menu).length) { %>
    <nav class="footer-nav" aria-label="站点导航">
      <%- partial('_partial/theme-menu', { mode: 'footer' }) %>
      <% if (theme.subnav && theme.subnav.github) { %>
        <span class="footer-nav-sep">·</span>
        <a href="<%- url_for(theme.subnav.github) %>" target="_blank" rel="noopener noreferrer">GitHub</a>
      <% } %>
    </nav>
    <% } else if (theme.subnav && theme.subnav.github) { %>
    <nav class="footer-nav" aria-label="社交">
      <a href="<%- url_for(theme.subnav.github) %>" target="_blank" rel="noopener noreferrer">GitHub</a>
    </nav>
    <% } %>
    <div id="footer-info">
      <div class="footer-left">
        &copy; <%= date(new Date(), 'YYYY') %> <%= config.author || config.title
        %>
      </div>
      <div class="footer-right">
        <a href="https://beian.miit.gov.cn/" target="_blank"
          >京ICP备16032693号</a
        >
      </div>
    </div>
  </div>
</footer>
