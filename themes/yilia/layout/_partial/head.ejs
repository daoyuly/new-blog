<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <%
  var title = page.title;

  if (is_archive()){
    title = 'Archives';

    if (is_month()){
      title += ': ' + page.year + '/' + page.month;
    } else if (is_year()){
      title += ': ' + page.year;
    }
  } else if (is_category()){
    title = 'Category: ' + page.category;
  } else if (is_tag()){
    title = 'Tag: ' + page.tag;
  }
  %>
  <meta name="renderer" content="webkit">
  <meta http-equiv="X-UA-Compatible" content="IE=edge" >
  <link rel="dns-prefetch" href="<%= config.url %>">
  <title><% if (title){ %><%= title %> | <% } %><%= config.title %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
  <%
  var siteKeywords = typeof page.keywords !== 'undefined' && page.keywords !== null && page.keywords !== ''
    ? page.keywords
    : config.keywords;
  if (siteKeywords) {
    var keywordsContent = Array.isArray(siteKeywords) ? siteKeywords.join(', ') : String(siteKeywords);
  %>
  <meta name="keywords" content="<%= keywordsContent %>">
  <% } %>
  <meta name="description" content="<%= page.description || page.excerpt || config.description %>">
  <link rel="canonical" href="<%= config.url %><%= url_for(page.path) %>">
  <%- open_graph({twitter_id: theme.twitter, google_plus: theme.google_plus, fb_admins: theme.fb_admins, fb_app_id: theme.fb_app_id}) %>
  <% if (theme.rss){ %>
    <link rel="alternative" href="<%- theme.rss %>" title="<%= config.title %>" type="application/atom+xml">
  <% } %>
  <% if (theme.favicon){ %>
    <link rel="icon" href="<%- theme.favicon %>">
  <% } %>
  <%- partial('css') %>
  <link rel="stylesheet" type="text/css" href="<%= config.root %>css/arthurchiao.css">
  <style type="text/css">
  <% var defaultCtnBg = '#fff' %>
    #container.show {
      background: <%= theme.style && theme.style.slider ? theme.style.slider : defaultCtnBg %>;
    }
  </style>
  <% if (page.noindex){ %>
  <meta name="robots" content="noindex,nofollow">
  <% } %>
  <% if (is_post() && !page.noindex){ %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "TechArticle",
    "headline": "<%= page.title %>",
    "description": "<%= (page.description || config.description || '').replace(/"/g, '\\"') %>",
    "author": {
      "@type": "Person",
      "name": "<%= page.author || config.author || '刘道玉' %>"
    },
    "publisher": {
      "@type": "Organization",
      "name": "<%= config.title %>",
      "url": "<%= config.url %>"
    },
    "datePublished": "<%= page.date.toISOString() %>",
    "dateModified": "<%= page.updated ? page.updated.toISOString() : page.date.toISOString() %>",
    "url": "<%= config.url %><%= url_for(page.path) %>",
    "inLanguage": "zh-CN",
    "keywords": "<%= page.keywords || (page.tags ? page.tags.map(function(t){return t.name}).join(', ') : '') %>"
  }
  </script>
  <% } %>
  <%- partial('baidu-analytics') %>  
</head>
